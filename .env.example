# BCP Calculator — Environment Configuration

# Default provider: deepseek (OpenAI-compatible API)
BCP_PROVIDER=deepseek
DEEPSEEK_API_KEY=your_deepseek_api_key_here
# DEEPSEEK_MODEL_NAME=deepseek-v4-flash  # default

# Alternative: OpenAI
# BCP_PROVIDER=openai
# OPENAI_API_KEY=your_openai_api_key_here
# OPENAI_MODEL_NAME=gpt-4o-2024-05-13

# Alternative: Anthropic Claude
# BCP_PROVIDER=claude
# ANTHROPIC_API_KEY=your_anthropic_api_key_here
# ANTHROPIC_MODEL_NAME=claude-3-sonnet-20240229-v1:0

# Flow API (C&T internal proxy)
# FLOW_CLIENT_ID=your_flow_client_id_here
# FLOW_CLIENT_SECRET=your_flow_client_secret_here
# FLOW_BASE_URL=https://flow.ciandt.com
# FLOW_TENANT=flowteam
# FLOW_AGENT=bcp-opensource
# FLOW_MODEL_NAME=gpt-4o-mini
# FLOW_MAX_TOKENS=4096

# Flow Bedrock
# FLOW_BEDROCK_MODEL_NAME=anthropic.claude-3-5-haiku
# FLOW_BEDROCK_MAX_TOKENS=1000
# FLOW_BEDROCK_TEMPERATURE=1.0
# FLOW_BEDROCK_TOP_P=0.999
# FLOW_BEDROCK_TOP_K=250
# FLOW_BEDROCK_ANTHROPIC_VERSION=bedrock-2023-05-31

# Optional
LOG_LEVEL=INFO
